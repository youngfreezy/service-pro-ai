# ============================================================
# ServicePro AI — Environment Variables
# Copy to .env and fill in values.
# ============================================================

# --- LLM Provider ---
# "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Docker Compose passwords (used by docker-compose.yml) ---
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
MINIO_ROOT_PASSWORD=change_me

# --- Postgres ---
DATABASE_URL=postgresql://servicepro:${POSTGRES_PASSWORD}@localhost:5435/servicepro

# --- Redis ---
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6381

# --- Auth ---
# Used by NextAuth for JWT signing. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=

# --- S3 / MinIO (photo storage) ---
# For local MinIO: S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=servicepro-photos
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=servicepro
AWS_SECRET_ACCESS_KEY=change_me
S3_ENDPOINT_URL=http://localhost:9000

# --- LangSmith (optional tracing) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=service-pro-ai

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO
